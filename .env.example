# Environment Variables for Razorpay Payment Integration

# RAZORPAY CONFIGURATION
RAZORPAY_KEY_ID=rzp_live_YOUR_KEY_ID
RAZORPAY_KEY_SECRET=YOUR_KEY_SECRET

# EMAIL CONFIGURATION (Gmail or other SMTP service)
EMAIL_SERVICE=gmail
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-specific-password
EMAIL_FROM=noreply@theniklaus.com
ADMIN_EMAIL=admin@theniklaus.com

# DATABASE CONFIGURATION (Frontend - requires VITE_ prefix)
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_FIREBASE_MEASUREMENT_ID=your_measurement_id

# APPLICATION
NODE_ENV=production
PORT=5000
CLIENT_URL=https://theniklaus.com

# Notes:
# 1. RAZORPAY_KEY_ID and RAZORPAY_KEY_SECRET: Get from your Razorpay Dashboard
#    - Visit: https://dashboard.razorpay.com/settings/api-keys
#    - Copy Key ID and Key Secret
#
# 2. EMAIL_PASSWORD: For Gmail, generate an App Password
#    - Visit: https://myaccount.google.com/apppasswords
#    - Enable 2-Factor Authentication first
#    - Generate app password for "Mail"
#
# 3. FIREBASE: Set up Firebase project at https://console.firebase.google.com/
#
# 4. Make sure to update these values in production environment
